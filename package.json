{
  "name": "@2digits/config-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Streamline your workflow with a bunch of default configs for things like eslint, tsconfig and prettier!",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run test lint:root types format lint:pkg lint:oxlint knip --continue",
    "check:watch": "turbo watch test lint:root types format lint:pkg",
    "clean": "find . -name node_modules -o -name .turbo -o -name dist -type d -prune | xargs rm -rf",
    "dev": "turbo run dev docs:dev",
    "docs": "turbo run docs",
    "fix": "pnpm '/(lint|format):fix$/'",
    "format": "vp fmt . --check",
    "format:fix": "vp fmt .",
    "knip": "knip",
    "lint": "turbo run lint:root lint:pkg lint:oxlint --continue",
    "lint:fix": "turbo run lint:pkg:fix lint:root --continue -- --fix",
    "lint:oxlint": "vp lint .",
    "lint:oxlint:fix": "vp lint . --fix",
    "lint:pkg": "manypkg check",
    "lint:pkg:fix": "manypkg fix",
    "lint:root": "eslint .",
    "oxlint": "vp lint .",
    "prepare": "effect-tsgo patch",
    "tegami": "node scripts/tegami.mts",
    "test": "turbo test",
    "types": "turbo types"
  },
  "devDependencies": {
    "@2digits/eslint-config": "workspace:*",
    "@2digits/oxfmt-config": "workspace:*",
    "@2digits/oxlint-config": "workspace:*",
    "@2digits/tsconfig": "workspace:*",
    "@effect/tsgo": "catalog:",
    "@manypkg/cli": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "pkg-pr-new": "catalog:",
    "tegami": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": "24.18.0"
  },
  "packageManager": "pnpm@11.15.0"
}
