{
  "$schema": "./node_modules/knip/schema.json",
  "ignoreDependencies": ["oxfmt"],
  "workspaces": {
    "packages/eslint-config": {
      "ignore": ["fixtures/**"],
      "ignoreDependencies": ["react", "@types/react"]
    },
    "packages/cli": {
      "ignore": ["test/fixtures/**"]
    },
    "packages/opencode-plugin": {
      "entry": ["src/index.ts", "bunup.config.ts"]
    },
    "packages/oxfmt-config": {
      "ignore": ["test/fixtures/**"]
    },
    "packages/tlo-mcp": {
      "ignoreDependencies": ["@typescript/native-preview"]
    }
  }
}
