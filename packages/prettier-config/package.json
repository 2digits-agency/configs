{
  "name": "@2digits/prettier-config",
  "version": "4.0.34",
  "keywords": [
    "prettier-config"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2digits-agency/configs.git",
    "directory": "packages/prettier-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack --minify --config-loader unconfig",
    "dev": "vp pack --watch --config-loader unconfig",
    "types": "tsgo --noEmit"
  },
  "dependencies": {
    "@2digits/constants": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "catalog:",
    "@prettier/plugin-oxc": "catalog:",
    "@prettier/plugin-xml": "catalog:",
    "local-pkg": "catalog:",
    "prettier-plugin-jsdoc": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@2digits/tsconfig": "workspace:*",
    "@arethetypeswrong/core": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "prettier": "catalog:"
  },
  "public": true
}
