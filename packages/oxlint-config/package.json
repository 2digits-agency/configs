{
  "name": "@2digits/oxlint-config",
  "version": "0.5.0",
  "description": "Minimal Oxlint config for 2digits projects.",
  "keywords": [
    "oxlint-config"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2digits-agency/configs.git",
    "directory": "packages/oxlint-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./base": "./dist/base.mjs",
    "./typescript": "./dist/typescript.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./base": "./dist/base.mjs",
      "./typescript": "./dist/typescript.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack --minify",
    "dev": "vp pack --watch",
    "rules:check": "tsx ./scripts/check-rules.ts",
    "types": "tsgo --noEmit"
  },
  "dependencies": {
    "@2digits/constants": "workspace:*",
    "@stylistic/eslint-plugin": "catalog:",
    "defu": "catalog:",
    "eslint-plugin-react-compiler": "catalog:"
  },
  "devDependencies": {
    "@2digits/tsconfig": "workspace:*",
    "@arethetypeswrong/core": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "dedent": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "publint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  },
  "public": true
}
