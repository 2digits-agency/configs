{
  "name": "@2digits/oxfmt-config",
  "version": "0.3.1",
  "description": "Opinionated Oxfmt config for 2digits projects.",
  "keywords": [
    "oxfmt-config"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2digits-agency/configs.git",
    "directory": "packages/oxfmt-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack --minify --config-loader unconfig",
    "dev": "vp pack --watch --config-loader unconfig",
    "test": "vp test run",
    "test:watch": "vp test",
    "types": "tsgo --noEmit"
  },
  "dependencies": {
    "@2digits/constants": "workspace:*",
    "defu": "catalog:"
  },
  "devDependencies": {
    "@2digits/prettier-config": "workspace:*",
    "@2digits/tsconfig": "workspace:*",
    "@arethetypeswrong/core": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "oxfmt": "catalog:"
  },
  "public": true
}
